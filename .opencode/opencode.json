{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://ollama:11434/v1"
      },
      "models": {
        "qwen3-coder:30b": {
          "name": "qwen3-coder:30b",
          "limit": {
            "context": 32768,
            "output": 65536
          }
        },
        "gpt-oss:20b-ctx128k": {
          "name": "gpt-oss:20b-ctx128k",
          "limit": {
            "context": 131072,
            "output": 65536
          }
        }
      }
    },
    "llama-qwen35-35b": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Llama.cpp",
      "options": {
        "baseURL": "http://llama-qwen35-35b:8080/v1"
      },
      "models": {
        "qwen35-35b": {
          "name": "qwen35-35b",
          "limit": {
            "context": 49152,
            "output": 65536
          }
        }
      }
    },
    "llama-qwen35-35b-3q": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Llama.cpp",
      "options": {
        "baseURL": "http://llama-qwen35-35b-q3:8080/v1"
      },
      "models": {
        "qwen35-35b-3q": {
          "name": "qwen35-35b-3q",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  },
  "mcp": {
    "kubernetes": {
      "enabled": true,
      "type": "remote",
      "url": "http://mcp-kubernetes:8080/mcp"
    },
    "grafana": {
      "enabled": true,
      "type": "remote",
      "url": "http://mcp-grafana:8000/mcp"
    },
    "photprism-mmontes": {
      "enabled": true,
      "type": "remote",
      "url": "http://mcp-photoprism-mmontes:9001/mcp"
    },
    "photprism-xiaowen": {
      "enabled": true,
      "type": "remote",
      "url": "http://mcp-photoprism-xiaowen:9001/mcp"
    },
	  "github": {
     	"type": "remote",
      "enabled": true,
			"url": "https://api.githubcopilot.com/mcp/",
			"headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}",
        "X-MCP-Readonly": "true"
      }
    }
  }
}